# Comma-separated list of frontend origins allowed to call this API.
# Set this in Render's dashboard under the backend service's Environment tab.
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=*

# ── Engineering Tutor ────────────────────────────────────────────────────
# Get a key from https://aistudio.google.com/app/apikey (free tier works).
GEMINI_API_KEY=

# Check https://ai.google.dev/gemini-api/docs/models for the current
# recommended Flash model if this default ever starts erroring as retired.
GEMINI_MODEL=gemini-2.5-flash

# Supabase project → Settings → API. SUPABASE_SERVICE_KEY is the
# "service_role" key, NOT the "anon"/"public" key — this runs server-side
# only and needs to bypass Row Level Security to write usage counters for
# anonymous visitors. Never expose the service_role key to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional — sensible defaults are in app/tutor/config.py if left unset.
# TUTOR_DAILY_LIMIT_PER_ANON=10
# TUTOR_DAILY_LIMIT_PER_IP=60
# TUTOR_COOLDOWN_SECONDS=15
# TUTOR_MAX_PROMPT_CHARS=300
# TUTOR_MAX_HISTORY_TURNS=4
# TUTOR_CACHE_TTL_DAYS=30
